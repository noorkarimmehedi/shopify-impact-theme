{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
VARIANT PICKER — Glass Cups with Bamboo Lid and Straw
----------------------------------------------------------------------------------------------------------------------
Card-style variant picker for the glass-cups-with-bamboo-lid-and-straw product.

3 variants:
  1. ২টি বাঁশের তৈরি ঢাকনা ও স্ট্রসহ গ্লাস কাপ  — Tk 980
  2. ৩টি বাঁশের তৈরি ঢাকনা ও স্ট্রসহ গ্লাস কাপ  — Tk 1,440
  3. ৪টি গ্লাস কাপ কিনলে ১টি ফ্রি!              — Tk 1,920  (countdown timer badge)

Variables:
* product  — the product object (required)
* form_id  — the product form id (required)
{%- endcomment -%}

<style>
  .gcup-picker {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
  }

  .gcup-picker__heading {
    text-align: center;
    font-size: 15px;
    font-weight: 700;
    color: #111;
    margin: 0 0 4px;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
  }

  /* Hidden native radio */
  .gcup-picker__input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .gcup-picker__card {
    position: relative;
    border: 2px solid #f5c6c6;
    border-radius: 12px;
    padding: 18px 16px;
    cursor: pointer;
    background: #ffffff;
    transition: border-color 0.2s, background 0.2s;
    display: flex;
    align-items: center;
    gap: 14px;
    overflow: hidden;
  }

  .gcup-picker__card:hover {
    border-color: #e53e3e;
  }

  .gcup-picker__card.is-selected {
    border-color: #e53e3e;
    background: #fff9e0;
  }

  /* Custom radio circle */
  .gcup-picker__radio {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 2.5px solid #ccc;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s;
  }

  .gcup-picker__card.is-selected .gcup-picker__radio {
    border-color: #e53e3e;
  }

  .gcup-picker__radio::after {
    content: '';
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: transparent;
    transition: background 0.2s;
  }

  .gcup-picker__card.is-selected .gcup-picker__radio::after {
    background: #e53e3e;
  }

  /* Title + subtitle group */
  .gcup-picker__text {
    flex: 1;
    min-width: 0;
  }

  .gcup-picker__title {
    font-size: 16px;
    font-weight: 700;
    color: #111;
    margin: 0;
    line-height: 1.35;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .gcup-picker__subtitle {
    font-size: 13px;
    color: #888;
    margin: 3px 0 0;
  }

  /* Price */
  .gcup-picker__price {
    font-size: 17px;
    font-weight: 700;
    color: #111;
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* Countdown timer badge */
  .gcup-picker__timer {
    position: absolute;
    top: -1px;
    right: 14px;
    background: #e53e3e;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 0 0 8px 8px;
    letter-spacing: 0.05em;
    font-variant-numeric: tabular-nums;
  }
</style>

<div class="gcup-picker" id="gcup-picker-{{ section.id }}">
  <p class="gcup-picker__heading">—————নিচের ৩টি অপশন থেকে ১টি সিলেক্ট করুন।—————</p>

  {%- assign subtitles = ",,মোট ৫টি ঢাকনা ও স্ট্রসহ কাচের কাপ" | split: "," -%}
  {%- assign show_timer = "false,false,true" | split: "," -%}
  {%- assign bundle_quantities = "2,3,5" | split: "," -%}

  {%- for variant in product.variants -%}
    {%- assign selected = false -%}
    {%- if variant == product.selected_or_first_available_variant -%}
      {%- assign selected = true -%}
    {%- endif -%}
    {%- assign subtitle = subtitles[forloop.index0] -%}
    {%- assign has_timer = show_timer[forloop.index0] -%}
    {%- assign bundle_qty = bundle_quantities[forloop.index0] | default: 1 -%}
    {%- assign price_text = variant.price | money_without_currency -%}

    <label
      class="gcup-picker__card{% if selected %} is-selected{% endif %}"
      for="gcup-variant-{{ variant.id }}"
      data-gcup-card
    >
      <input
        class="gcup-picker__input"
        type="radio"
        name="id"
        id="gcup-variant-{{ variant.id }}"
        form="{{ form_id }}"
        value="{{ variant.id }}"
        {% if selected %}checked{% endif %}
        {% unless variant.available %}disabled{% endunless %}
        data-gcup-radio
        data-gcup-qty="{{ bundle_qty }}"
        data-gcup-price="{{ variant.price }}"
        data-gcup-price-text="{{ price_text | escape }}"
      >

      {%- if has_timer == 'true' -%}
        <span class="gcup-picker__timer" data-gcup-timer></span>
      {%- endif -%}

      <div class="gcup-picker__radio"></div>

      <div class="gcup-picker__text">
        <p class="gcup-picker__title">{{ variant.title }}</p>
        {%- if subtitle != blank -%}
          <p class="gcup-picker__subtitle">{{ subtitle }}</p>
        {%- endif -%}
      </div>

      <span class="gcup-picker__price">Tk {{ price_text }}</span>
    </label>
  {%- endfor -%}
</div>

<script>
  (function() {
    var picker = document.getElementById('gcup-picker-{{ section.id }}');
    if (!picker) return;

    function getProductForm() {
      return document.getElementById('{{ form_id }}');
    }

    function getOrCreateFormInput(name, id) {
      var form = getProductForm();
      if (!form) return null;

      var input = form.querySelector('[name="' + name + '"]');

      if (!input) {
        input = document.createElement('input');
        input.type = 'hidden';
        input.name = name;
        input.id = id;
        form.appendChild(input);
      }

      return input;
    }

    function syncBundleMetadata(radio) {
      var bundleQuantity = radio.getAttribute('data-gcup-qty');
      var bundlePrice = radio.getAttribute('data-gcup-price');
      var bundlePriceText = radio.getAttribute('data-gcup-price-text');
      if (!bundleQuantity) return;

      var quantityInput = getOrCreateFormInput('quantity', '{{ form_id }}-quantity');
      var bundleQuantityInput = getOrCreateFormInput('properties[Bundle item count]', '{{ form_id }}-bundle-item-count');
      var bundleDisplayQuantityInput = getOrCreateFormInput('properties[_Display quantity]', '{{ form_id }}-bundle-display-quantity');

      if (quantityInput) {
        quantityInput.value = '1';
        quantityInput.dispatchEvent(new Event('input', { bubbles: true }));
        quantityInput.dispatchEvent(new Event('change', { bubbles: true }));
      }

      if (bundleQuantityInput) {
        bundleQuantityInput.value = bundleQuantity;
      }

      if (bundleDisplayQuantityInput) {
        bundleDisplayQuantityInput.value = bundleQuantity;
      }

      window.gcupBundleSelection = {
        variantId: radio.value,
        quantity: bundleQuantity,
        orderQuantity: '1',
        price: bundlePrice,
        priceText: bundlePriceText
      };

      document.dispatchEvent(new CustomEvent('gcup:bundle-change', {
        detail: window.gcupBundleSelection
      }));

      syncCodDisplay(window.gcupBundleSelection);
    }

    function isInsideProductForm(element) {
      return Boolean(element.closest('#{{ form_id }}'));
    }

    function syncCodDisplay(selection) {
      var codContainers = Array.from(document.querySelectorAll([
        '[class*="cod" i]',
        '[id*="cod" i]',
        '[class*="cash" i]',
        '[id*="cash" i]',
        '[class*="order" i]',
        '[id*="order" i]',
        '[class*="checkout" i]',
        '[id*="checkout" i]',
        '[class*="delivery" i]',
        '[id*="delivery" i]'
      ].join(','))).filter(function(container) {
        return !isInsideProductForm(container);
      });

      if (!codContainers.length) return;

      var quantitySelectors = [
        'input[name*="quantity" i]',
        'input[id*="quantity" i]',
        'input[class*="quantity" i]',
        'input[name*="qty" i]',
        'input[id*="qty" i]',
        'input[class*="qty" i]',
        'select[name*="quantity" i]',
        'select[id*="quantity" i]',
        'select[class*="quantity" i]',
        'select[name*="qty" i]',
        'select[id*="qty" i]',
        'select[class*="qty" i]'
      ].join(',');

      codContainers.forEach(function(container) {
        container.querySelectorAll(quantitySelectors).forEach(function(input) {
          if (isInsideProductForm(input)) return;

          input.value = selection.quantity;
          input.setAttribute('data-gcup-display-quantity', selection.quantity);
          input.dispatchEvent(new Event('input', { bubbles: true }));
          input.dispatchEvent(new Event('change', { bubbles: true }));
        });
      });

      var priceSelectors = [
        '[data-gcup-bundle-price]',
        '[data-total-price]',
        '[data-subtotal]',
        '[class*="total" i]',
        '[id*="total" i]',
        '[class*="subtotal" i]',
        '[id*="subtotal" i]',
        '[class*="price" i]',
        '[id*="price" i]'
      ].join(',');

      codContainers.forEach(function(container) {
        container.querySelectorAll(priceSelectors).forEach(function(element) {
          if (isInsideProductForm(element) || element.matches('input, select, textarea')) return;

          var text = element.textContent || '';

          if (/৳|Tk|BDT|টাকা|total|subtotal|price/i.test(text + ' ' + element.className + ' ' + element.id)) {
            element.textContent = 'Tk ' + selection.priceText;
            element.setAttribute('data-gcup-bundle-price', selection.priceText);
          }
        });
      });
    }

    var checkedRadio = picker.querySelector('[data-gcup-radio]:checked');

    if (checkedRadio) {
      syncBundleMetadata(checkedRadio);
    }

    // Toggle selected state on radio change and keep checkout quantity as one bundle.
    picker.addEventListener('change', function(e) {
      if (!e.target.matches('[data-gcup-radio]')) return;
      picker.querySelectorAll('[data-gcup-card]').forEach(function(card) {
        card.classList.remove('is-selected');
      });
      e.target.closest('[data-gcup-card]').classList.add('is-selected');
      syncBundleMetadata(e.target);
    });

    document.addEventListener('click', function() {
      var selected = window.gcupBundleSelection;
      if (!selected) return;

      window.setTimeout(function() {
        syncCodDisplay(selected);
      }, 50);
      window.setTimeout(function() {
        syncCodDisplay(selected);
      }, 300);
    });

    if ('MutationObserver' in window) {
      new MutationObserver(function() {
        var selected = window.gcupBundleSelection;
        if (!selected) return;

        window.requestAnimationFrame(function() {
          syncCodDisplay(selected);
        });
      }).observe(document.body, { childList: true, subtree: true });
    }

    // Countdown timer — counts down from 13:00:00 and loops
    var timerEl = picker.querySelector('[data-gcup-timer]');
    if (!timerEl) return;

    var storageKey = 'gcup_timer_end_{{ section.id }}';
    var durationMs = 13 * 60 * 60 * 1000; // 13 hours

    var endTime = parseInt(sessionStorage.getItem(storageKey), 10);
    if (!endTime || endTime < Date.now()) {
      endTime = Date.now() + durationMs;
      sessionStorage.setItem(storageKey, endTime);
    }

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function tick() {
      var remaining = endTime - Date.now();
      if (remaining <= 0) {
        endTime = Date.now() + durationMs;
        sessionStorage.setItem(storageKey, endTime);
        remaining = durationMs;
      }
      var h = Math.floor(remaining / 3600000);
      var m = Math.floor((remaining % 3600000) / 60000);
      var s = Math.floor((remaining % 60000) / 1000);
      timerEl.textContent = pad(h) + ' : ' + pad(m) + ' : ' + pad(s);
    }

    tick();
    setInterval(tick, 1000);
  })();
</script>
